from pyspark.sql import SparkSession
from pyspark.sql.functions import col, avg, sum, min, max, count, desc

# Initialize the Spark Session
spark = SparkSession.builder \
    .appName("Celebal_Spark_Assignment_5") \
    .config("spark.sql.legacy.timeParserPolicy", "LEGACY") \
    .getOrCreate()

print("Spark Session Created Successfully!")


dataset_path = "/kaggle/input/datasets/vivek468/superstore-dataset-final/Sample - Superstore.csv"

df = spark.read.csv(
    dataset_path, 
    header=True, 
    inferSchema=True, 
    quote='"', 
    escape='"', 
    multiLine=True
)

print("\n--- INITIAL DATAFRAME SCHEMA ---")
df.printSchema()


print("\n--- STEP 4: DATA CLEANING ---")

# 1. Total row count before cleaning
initial_count = df.count()
print(f"Initial Row Count: {initial_count}")

# 2. Remove duplicate rows
df_deduped = df.dropDuplicates()
deduped_count = df_deduped.count()
print(f"Row Count after dropping duplicates: {deduped_count}")

# 3. Handling missing/null values
df_cleaned = df_deduped.na.drop(subset=["Order ID", "Customer ID"])
df_cleaned = df_cleaned.na.fill({"Postal Code": 0, "Sales": 0.0, "Quantity": 0})

print(f"Row Count after handling crucial null values: {df_cleaned.count()}")


print("\n--- STEP 5 & 6: FILTER & TRANSFORMATION ---")

df_transformed = df_cleaned \
    .withColumnRenamed("Order Date", "Order_Date") \
    .withColumnRenamed("Sub-Category", "Sub_Category") \
    .withColumnRenamed("Ship Mode", "Ship_Mode")

# Transformation: Change data types 
df_transformed = df_transformed \
    .withColumn("Sales", col("Sales").cast("double")) \
    .withColumn("Profit", col("Profit").cast("double")) \
    .withColumn("Quantity", col("Quantity").cast("integer"))

df_filtered = df_transformed.filter((col("Region") == "West") & (col("Category") == "Technology"))
print(f"Filtered Rows (Region: West & Category: Technology): {df_filtered.count()}")


print("\n--- STEP 7: BASIC AGGREGATIONS (Global Metrics) ---")

global_metrics = df_transformed.select(
    count("Order ID").alias("Total_Orders"),
    avg("Sales").alias("Average_Sales"),
    sum("Profit").alias("Total_Profit"),
    min("Quantity").alias("Minimum_Quantity_Ordered"),
    max("Quantity").alias("Maximum_Quantity_Ordered")
)
global_metrics.show()


print("\n--- STEP 8: GROUP BY & REGIONAL/CATEGORY ANALYSIS ---")

# Grouping by Category and Sub-Category to check Performance
grouped_df = df_transformed.groupBy("Category", "Sub_Category") \
    .agg(
        count("Order ID").alias("Item_Count"),
        sum("Sales").alias("Total_Sales"),
        avg("Profit").alias("Average_Profit")
    ) \
    .filter(col("Total_Sales") > 5000) \
    .orderBy(desc("Total_Sales"))

grouped_df.show(20, truncate=False)


print("\n--- STEP 10: END-TO-END PIPELINE PROCESSING ---")

def run_superstore_pipeline(input_path):
    # Added robust quote and escape parameters to match our fixed step 3
    raw_df = spark.read.csv(
        input_path, 
        header=True, 
        inferSchema=True, 
        quote='"', 
        escape='"', 
        multiLine=True
    )
    
    # Clean & Transform
    processed_df = raw_df.dropDuplicates() \
                         .na.fill({"Sales": 0.0, "Profit": 0.0}) \
                         .withColumnRenamed("Sub-Category", "Sub_Category") \
                         .withColumn("Sales", col("Sales").cast("double"))
    
    # Aggregate
    summary_df = processed_df.groupBy("Segment", "Region") \
                             .agg(sum("Sales").alias("Total_Regional_Sales")) \
                             .orderBy("Segment", desc("Total_Regional_Sales"))
    
    return summary_df

# Execute the pipeline
pipeline_result = run_superstore_pipeline(dataset_path)
pipeline_result.show()

# Exporting the result to local workspace to fulfill the output requirement
pipeline_result.coalesce(1).write.csv("pipeline_summary_results", header=True, mode="overwrite")
print("Results successfully exported to 'pipeline_summary_results' folder!")



